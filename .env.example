# =============================================================================
# .env.example — copy to .env and fill all values before running
# Generate UUIDs on Linux: uuidgen
# =============================================================================

# --- Wazuh ---
WAZUH_INDEXER_USERNAME=admin
WAZUH_INDEXER_PASSWORD=SecretPassword          # change this
WAZUH_API_USERNAME=wazuh-wui
WAZUH_API_PASSWORD=MyS3cr37P450r              # change this (min 8 chars, 1 uppercase, 1 special)

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest                   # change in production

# --- OpenCTI ---
OPENCTI_ADMIN_EMAIL=admin@opencti.io
OPENCTI_ADMIN_PASSWORD=ChangeMePlease
OPENCTI_ADMIN_TOKEN=ChangeMe_UUIDv4           # generate with: uuidgen
OPENCTI_BASE_URL=http://localhost:8080

# --- MinIO (used by OpenCTI) ---
MINIO_ROOT_USER=opencti
MINIO_ROOT_PASSWORD=ChangeMePlease12          # min 8 chars

# --- MISP ---
MISP_BASEURL=http://localhost:8888
MISP_ADMIN_EMAIL=admin@misp.local
MISP_ADMIN_PW=ChangeMePlease
MYSQL_ROOT_PASSWORD=rootpassword              # change this
MYSQL_MISP_PASSWORD=misp                      # change this

# --- Shuffle ---
SHUFFLE_DB_PASSWORD=shufflepassword           # change this

# --- n8n ---
N8N_API_KEY=ChangeMePlease
N8N_WEBHOOK_URL=http://localhost:5678/

# --- SMTP (optional, used by OpenCTI notifications) ---
SMTP_HOSTNAME=localhost
